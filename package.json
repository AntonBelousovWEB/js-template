{
	"name": "js-template",
	"type": "module",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "node server.mjs",
		"dev:spa": "vite",
		"build": "tsc -b && vite build --outDir dist/client && vite build --ssr src/entry-server.tsx --outDir dist/server",
		"preview": "NODE_ENV=production node server.mjs",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "NODE_OPTIONS=--max-old-space-size=6144 vitest",
		"test:ui": "NODE_OPTIONS=--max-old-space-size=6144 vitest --ui",
		"test:run": "NODE_OPTIONS=--max-old-space-size=6144 vitest run",
		"test:coverage": "NODE_OPTIONS=--max-old-space-size=6144 vitest --coverage",
		"template:reset": "node scripts/reset-template.mjs",
		"prepare": "husky"
	},
	"dependencies": {
		"@mantine/core": "^9.4.1",
		"@mantine/hooks": "^9.4.1",
		"@needle-di/core": "^1.1.0",
		"@reatom/core": "^1000.0.0-alpha.51",
		"@reatom/react": "^1000.0.0-alpha.50",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-router-dom": "^6.26.2"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^4.0.0",
		"@babel/plugin-proposal-decorators": "^7.28.0",
		"@eslint-react/eslint-plugin": "^1.53.1",
		"@eslint/js": "^9.33.0",
		"@types/node": "^24.5.1",
		"@types/react": "^19.1.10",
		"@types/react-dom": "^19.1.7",
		"@vitejs/plugin-react": "^5.0.0",
		"eslint": "^9.33.0",
		"eslint-plugin-format": "^2.0.1",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"globals": "^16.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.2.11",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.39.1",
		"vite": "^7.1.2",
		"vitest": "^4.0.13"
	},
	"husky": {
		"hooks": {
			"pre-commit": "npx lint-staged"
		}
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix",
			"vitest related --run --reporter=verbose"
		],
		"*.{json,css,scss,html}": [
			"eslint --fix"
		]
	}
}
